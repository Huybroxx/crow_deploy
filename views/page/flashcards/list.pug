extends ../../layout/default.pug
include ../../mixin/alert.pug

block style
    style.
        table {
            font-size: 1.1rem;
            font-weight: 600;
        }
        th, td {
            vertical-align: middle;
            padding: 10px;
        }
        .x {
            min-height: 100vh;
            display: flex;

            margin-top: 8rem;
            margin-bottom: 3rem;
            max-width: 1400px;
            margin-left: auto;
            margin-right: auto;
            padding-left: 15px;
            padding-right: 15px;
            width: 100%;
            display: block;
        }

        /* Từ vựng: cam lợt */
        td.vocab {
            background-color:rgb(255, 249, 242); /* cam lợt */
        }
        .list-card-cell {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        .list-card-thumb {
            width: 54px;
            height: 54px;
            object-fit: cover;
            border-radius: 10px;
            border: 2px solid #ffd6a1;
            background: #fff7ef;
        }
        .flashcard-list-data {
            display: none;
        }
        .flashcard-list-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 16px;
            padding: 12px;
            border: 1px solid #ffe0b8;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.82);
            box-shadow: 0 12px 28px rgba(255, 169, 70, 0.12);
        }
        .flashcard-list-actions,
        .flashcard-layout-toggle {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        .flashcard-postcard-panel {
            display: none;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            flex-wrap: wrap;
            margin-bottom: 16px;
            padding: 14px;
            border: 1px solid #ffd6a1;
            border-radius: 14px;
            background: #fffaf4;
            box-shadow: 0 10px 24px rgba(255, 169, 70, 0.14);
        }
        .flashcard-postcard-panel.is-open {
            display: flex;
        }
        .postcard-info {
            min-width: 220px;
        }
        .postcard-title {
            margin: 0 0 4px;
            color: #8a4f13;
            font-size: 1rem;
            font-weight: 800;
        }
        .postcard-status {
            margin: 0;
            color: #7b6b5b;
            font-size: 0.92rem;
            font-weight: 600;
        }
        .postcard-controls,
        .postcard-speed {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        .postcard-speed {
            color: #8a4f13;
            font-weight: 700;
        }
        .postcard-speed input {
            width: 150px;
            accent-color: #ffa94d;
        }
        .list-control-btn,
        .list-layout-btn {
            min-height: 40px;
            border: 1px solid #ffd6a1;
            border-radius: 10px;
            padding: 8px 12px;
            background: #fffaf4;
            color: #8a4f13;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
        }
        .list-control-btn:hover,
        .list-layout-btn:hover {
            transform: translateY(-1px);
            border-color: #ffa94d;
            background: #fff2df;
        }
        .list-control-btn.is-active,
        .list-layout-btn.active {
            color: #fff;
            border-color: #ffa94d;
            background: linear-gradient(90deg, #ffa946 0%, #ffc07b 100%);
            box-shadow: 0 8px 18px rgba(255, 169, 70, 0.26);
        }
        .list-control-btn:disabled {
            cursor: not-allowed;
            opacity: 0.55;
            transform: none;
        }
        .list-table-wrap {
            width: 100%;
            overflow-x: auto;
            border-radius: 14px;
        }
        #flashcard-list-table {
            min-width: 720px;
        }
        #flashcard-list-table[data-columns="1"] {
            min-width: 420px;
        }
        .list-reveal-cell {
            cursor: pointer;
        }
        .list-reveal-cell:hover {
            box-shadow: inset 0 0 0 2px rgba(255, 169, 77, 0.34);
        }
        .list-reveal-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 54px;
            height: 54px;
            border: 2px dashed #ffc47d;
            border-radius: 12px;
            background: #fff2df;
            color: #d77912;
            font-size: 1.8rem;
            font-weight: 900;
            line-height: 1;
            cursor: pointer;
        }
        .list-meaning-cover {
            width: 100%;
            min-height: 42px;
        }
        .list-empty-cell {
            background: rgba(255, 250, 244, 0.74);
        }

        /* Nghĩa: cam nhạt hơn */
        td.meaning {
            background-color:rgb(255, 253, 252); /* cam nhạt */
        }

        th {
            background-color: #ffa94d !important;
            color: white;
            resize: horizontal;
            overflow: auto;
            min-width: 100px;
        }
        table {
            font-size: 1.1rem;
            font-weight: 600;
            table-layout: auto; /* Cho phép tự co giãn */
            width: 100%;
        }
        tr:hover {
            background-color: #ffecb5 !important; /* cam nhạt */
        }
        footer {
            display: none;
        }
        @media (max-width: 768px) {
            .flashcard-list-toolbar {
                align-items: stretch;
            }
            .flashcard-list-actions,
            .flashcard-layout-toggle,
            .list-control-btn,
            .list-layout-btn {
                width: 100%;
            }
            .flashcard-layout-toggle {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

block main
    +alert-success(5000)
    +alert-error(5000)

    .x.mt-5
        .x
            h2.text-center.mb-4 #{title}
            - const cards = flashCard.cards || []
            if cards.length
                .flashcard-list-data(data-cards=JSON.stringify(cards) data-flashcard-id=flashCard._id)
                .flashcard-list-toolbar
                    .flashcard-list-actions
                        button#study-mode-toggle.list-control-btn(type="button" aria-pressed="false")
                            i.fas.fa-graduation-cap.mr-2
                            span.list-study-label Chế độ học
                        button#postcard-toggle.list-control-btn(type="button" aria-expanded="false")
                            i.fas.fa-volume-high.mr-2
                            | Postcard
                    .flashcard-layout-toggle(role="group" aria-label="Chế độ hiển thị")
                        button.list-layout-btn(type="button" data-columns="1" aria-pressed="false")
                            i.fas.fa-list.mr-2
                            |  1 cột
                        button.list-layout-btn.active(type="button" data-columns="2" aria-pressed="true")
                            i.fas.fa-columns.mr-2
                            |  2 cột
                .flashcard-postcard-panel#postcard-panel(aria-live="polite")
                    .postcard-info
                        p.postcard-title
                            i.fas.fa-headphones.mr-2
                            | Postcard đọc bộ thẻ
                        p#postcard-status.postcard-status Sẵn sàng đọc #{cards.length} thẻ
                    .postcard-controls
                        button#postcard-play.list-control-btn(type="button")
                            i.fas.fa-play.mr-2
                            | Đọc từ đầu
                        button#postcard-pause.list-control-btn(type="button")
                            i.fas.fa-pause.mr-2
                            | Tạm dừng
                        button#postcard-stop.list-control-btn(type="button")
                            i.fas.fa-stop.mr-2
                            | Dừng
                    label.postcard-speed(for="postcard-speed")
                        i.fas.fa-gauge-high.mr-2
                        | Tốc độ
                        input#postcard-speed(type="range" min="0.5" max="1.8" step="0.1" value="1")
                        span#postcard-speed-value 1.0x
                .list-table-wrap
                    table#flashcard-list-table.table.table-bordered.table-striped.table-hover.text-center(data-columns="2")
                        thead.table-dark
                            tr#flashcard-list-head
                                th(style="width: 25%") Từ vựng
                                th(style="width: 25%") Nghĩa
                                th(style="width: 25%") Từ vựng
                                th(style="width: 25%") Nghĩa
                        tbody#flashcard-list-body
                            - for (let i = 0; i < cards.length; i += 2)
                                tr
                                    td.vocab
                                        .list-card-cell
                                            if cards[i].previewUrl
                                                img.list-card-thumb(src=cards[i].previewUrl alt=cards[i].vocabulary)
                                            span #{cards[i].vocabulary}
                                    td.meaning #{cards[i].meaning}
                                    if cards[i + 1]
                                        td.vocab
                                            .list-card-cell
                                                if cards[i + 1].previewUrl
                                                    img.list-card-thumb(src=cards[i + 1].previewUrl alt=cards[i + 1].vocabulary)
                                                span #{cards[i + 1].vocabulary}
                                        td.meaning #{cards[i + 1].meaning}
                                    else
                                        td.list-empty-cell(colspan="2")

            else
                .alert.alert-warning.text-center Không có từ nào trong bộ thẻ này.
block script2
    script(src="/js/flashcard/list.js" type="module")
