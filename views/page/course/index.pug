extends ../../layout/default.pug
include ../../mixin/alert.pug
block style
  link(rel="stylesheet" href="./css/course.css")
  link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css")

block main
  section.courses
    h1 Our Courses
    p.subtitle Khám phá khóa học hay nhất
    p.description Trong suốt thời gian đó, chúng tôi đã định hình cách mọi người vào đại học để họ có thể học hỏi và phát triển từ trải nghiệm này.

  div.section-all
    div.course-container
      div.wrap
        // Duyệt qua từng khóa học và hiển thị thông tin
        each course in courses
          a(href=`/course/detail/${course.id}`)
            div.course-card
              img(src=`${course.thumbnail}` alt=course.name)
              h3= course.name
              p 📚 #{course.lessons.length} Lesson
              p
                // Hiển thị sao cho khóa học
                - var rating = 3 // Giả sử bạn có rating sao từ cơ sở dữ liệu
                each star in [1, 2, 3, 4, 5]
                  if star <= rating
                    i.fas.fa-star
                  else
                    i.fas.fa-star-half-alt

    // Pagination
    if totalPages > 1
      .pagination-container(style="display: flex; justify-content: center; align-items: center; margin: 40px 0; gap: 10px;")
        if hasPrevPage
          a.pagination-btn(href=`/course?page=${currentPage - 1}` style="padding: 12px 24px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 8px; text-decoration: none; font-weight: 600; transition: all 0.3s;") ← Trước
        else
          span.pagination-btn.disabled(style="padding: 12px 24px; background: #e0e0e0; color: #999; border-radius: 8px; cursor: not-allowed;") ← Trước

        span.pagination-info(style="padding: 12px 24px; font-weight: 600; color: #333; background: #f5f5f5; border-radius: 8px;") Trang #{currentPage} / #{totalPages}

        if hasNextPage
          a.pagination-btn(href=`/course?page=${currentPage + 1}` style="padding: 12px 24px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 8px; text-decoration: none; font-weight: 600; transition: all 0.3s;") Tiếp →
        else
          span.pagination-btn.disabled(style="padding: 12px 24px; background: #e0e0e0; color: #999; border-radius: 8px; cursor: not-allowed;") Tiếp →