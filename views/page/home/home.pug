extends ../../layout/default.pug
include ../../mixin/alert.pug

block style
    link(rel="stylesheet" href="./css/home.css")

block main
    +alert-success(5000)
    +alert-error(5000)

    // Hero Section
    section#hero.hero-section(data-scroll-section)
        .hero-background
            .gradient-orb.orb-1
            .gradient-orb.orb-2
            .gradient-orb.orb-3
        .container
            .hero-content(data-animate="fade-up")
                .hero-badge(data-animate="fade-up" data-delay="100")
                    span.badge-icon 🎓
                    span 50% OFF - Ưu đãi đặc biệt
                h1.hero-title(data-animate="fade-up" data-delay="200")
                    span.title-line Ngôn ngữ là
                    span.title-highlight chìa khóa
                    span.title-line mở ra tương lai
                p.hero-description(data-animate="fade-up" data-delay="300")
                    | Chúng tôi cung cấp các khóa học phù hợp với mục tiêu và sở thích của bạn.
                    | Học thông minh, tiến bộ nhanh chóng cùng Crow.
                .hero-actions(data-animate="fade-up" data-delay="400")
                    a.btn.btn-primary(href="/course")
                        span Bắt đầu học
                        i.icon ➜
                    button.btn.btn-video
                        span.video-icon ▶
                        span Xem giới thiệu
            .hero-image(data-animate="fade-left" data-delay="300")
                .stats-card(data-animate="scale-up" data-delay="600")
                    .stats-icon 📚
                    .stats-number 100+
                    .stats-label Bài giảng
                .image-wrapper
                    .floating-elements
                        .float-item.float-1 ✨
                        .float-item.float-2 🌟
                        .float-item.float-3 ⭐
                    img(src="./img/img-home/image-try.png" alt="Học tập" class="hero-img")

    // Features Section
    section#features.features-section(data-scroll-section)
        .container
            .section-header(data-animate="fade-up")
                span.section-badge 🚀 Tính năng nổi bật
                h2.section-title Ôn luyện đa dạng, hiệu quả
                p.section-subtitle Học tập với nhiều phương pháp khác nhau để tối ưu kết quả
            .features-grid
                .feature-card(data-animate="fade-up" data-delay="100")
                    .feature-icon(style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%)")
                        img(src="./img/img-home/pencil.png" alt="Trắc nghiệm")
                    h3.feature-title Trắc nghiệm
                    p.feature-desc Luyện tập với hàng nghìn câu hỏi
                .feature-card(data-animate="fade-up" data-delay="150")
                    .feature-icon(style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%)")
                        img(src="./img/img-home/science.png" alt="Trả lời ngắn")
                    h3.feature-title Trả lời ngắn
                    p.feature-desc Rèn luyện kỹ năng viết tự nhiên
                .feature-card(data-animate="fade-up" data-delay="200")
                    .feature-icon(style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)")
                        img(src="./img/img-home/tech.png" alt="Điền từ")
                    h3.feature-title Điền từ
                    p.feature-desc Cải thiện khả năng ngữ cảnh
                .feature-card(data-animate="fade-up" data-delay="250")
                    .feature-icon(style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)")
                        img(src="./img/img-home/med.svg" alt="Mini game")
                    h3.feature-title Mini game
                    p.feature-desc Học qua trò chơi thú vị
                .feature-card(data-animate="fade-up" data-delay="300")
                    .feature-icon(style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%)")
                        img(src="./img/img-home/math.svg" alt="Sắp xếp")
                    h3.feature-title Sắp xếp hội thoại
                    p.feature-desc Thực hành giao tiếp thực tế
                .feature-card(data-animate="fade-up" data-delay="350")
                    .feature-icon(style="background: linear-gradient(135deg, #30cfd0 0%, #330867 100%)")
                        img(src="./img/img-home/food-delivery.png" alt="Hình ảnh")
                    h3.feature-title Hình ảnh
                    p.feature-desc Ghi nhớ qua thị giác
                .feature-card(data-animate="fade-up" data-delay="400")
                    .feature-icon(style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%)")
                        img(src="./img/img-home/graduating-student.png" alt="Thẻ học")
                    h3.feature-title Thẻ học tập
                    p.feature-desc Flashcard thông minh
                .feature-card(data-animate="fade-up" data-delay="450")
                    .feature-icon(style="background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%)")
                        img(src="./img/img-home/art-book.svg" alt="Luyện nghe")
                    h3.feature-title Luyện nghe
                    p.feature-desc Phát âm chuẩn bản ngữ

    // Courses Section
    section#courses.courses-section(data-scroll-section)
        .container
            .section-header(data-animate="fade-up")
                span.section-badge 📚 Khóa học
                h2.section-title Khóa học phổ biến nhất
                p.section-subtitle Được yêu thích bởi hàng nghìn học viên
            .courses-grid
                .course-card(data-animate="fade-up" data-delay="100")
                    .course-image
                        img(src="./img/img-home/course-1.png" alt="Course")
                        .course-badge HOT
                    .course-content
                        h3.course-title 30 ngày học tiếng Anh cho người mới bắt đầu
                        .course-meta
                            span.meta-item 📚 1500 học viên
                            span.meta-item ⭐ 4.8/5
                        .course-footer
                            span.course-price Miễn phí
                            button.btn-enroll Tham gia →
                .course-card(data-animate="fade-up" data-delay="150")
                    .course-image
                        img(src="./img/img-home/course-2.png" alt="Course")
                        .course-badge NEW
                    .course-content
                        h3.course-title Giao tiếp tiếng Anh trong công việc
                        .course-meta
                            span.meta-item 📚 2300 học viên
                            span.meta-item ⭐ 4.9/5
                        .course-footer
                            span.course-price Miễn phí
                            button.btn-enroll Tham gia →
                .course-card(data-animate="fade-up" data-delay="200")
                    .course-image
                        img(src="./img/img-home/course-3.png" alt="Course")
                    .course-content
                        h3.course-title Luyện thi IELTS 6.5+ hiệu quả
                        .course-meta
                            span.meta-item 📚 1800 học viên
                            span.meta-item ⭐ 4.7/5
                        .course-footer
                            span.course-price Miễn phí
                            button.btn-enroll Tham gia →
                .course-card(data-animate="fade-up" data-delay="250")
                    .course-image
                        img(src="./img/img-home/course-4.png" alt="Course")
                    .course-content
                        h3.course-title Tiếng Anh qua phim và bài hát
                        .course-meta
                            span.meta-item 📚 3200 học viên
                            span.meta-item ⭐ 5.0/5
                        .course-footer
                            span.course-price Miễn phí
                            button.btn-enroll Tham gia →

    // Benefits Section
    section#benefits.benefits-section(data-scroll-section)
        .container
            .section-header(data-animate="fade-up")
                span.section-badge ✨ Lợi ích
                h2.section-title Tại sao chọn Crow?
                p.section-subtitle Nền tảng học tập toàn diện cho mọi cấp độ
            .benefits-grid
                .benefit-card(data-animate="fade-up" data-delay="100")
                    .benefit-icon
                        span 📖
                    h3.benefit-title Từ vựng phong phú
                    p.benefit-desc Hơn 170.000+ từ vựng được phân loại theo chủ đề và cấp độ
                .benefit-card(data-animate="fade-up" data-delay="150")
                    .benefit-icon
                        span 🎯
                    h3.benefit-title Lộ trình cá nhân hóa
                    p.benefit-desc AI tự động điều chỉnh theo trình độ và mục tiêu của bạn
                .benefit-card(data-animate="fade-up" data-delay="200")
                    .benefit-icon
                        span 👥
                    h3.benefit-title Cộng đồng năng động
                    p.benefit-desc Kết nối với hàng nghìn học viên cùng chí hướng
                .benefit-card(data-animate="fade-up" data-delay="250")
                    .benefit-icon
                        span 📊
                    h3.benefit-title Theo dõi tiến độ
                    p.benefit-desc Thống kê chi tiết giúp bạn nắm rõ quá trình học tập

    // Testimonials Section
    section#testimonials.testimonials-section(data-scroll-section)
        .container
            .section-header(data-animate="fade-up")
                span.section-badge 💬 Đánh giá
                h2.section-title Học viên nói gì về Crow
                p.section-subtitle Những chia sẻ chân thực từ cộng đồng
            .testimonials-wrapper
                .testimonial-card(data-animate="fade-up" data-delay="100")
                    .testimonial-content
                        .quote-icon "
                        p.testimonial-text Học với Crow đã giúp tôi đạt được mục tiêu thi chứng chỉ ngoại ngữ trong thời gian ngắn. Tôi rất biết ơn đội ngũ phát triển trang web này!
                    .testimonial-author
                        .author-avatar
                            img(src="./img/img-home/course-2.png" alt="Ly Ly")
                        .author-info
                            h4.author-name Ly Ly
                            p.author-role Ca sĩ
                        .rating
                            span ⭐⭐⭐⭐⭐
                .testimonial-card(data-animate="fade-up" data-delay="150")
                    .testimonial-content
                        .quote-icon "
                        p.testimonial-text Giao diện đẹp, dễ sử dụng. Các bài học được sắp xếp khoa học. Tôi đã cải thiện đáng kể khả năng giao tiếp tiếng Anh của mình.
                    .testimonial-author
                        .author-avatar
                            img(src="./img/Avata.png" alt="Minh Anh")
                        .author-info
                            h4.author-name Minh Anh
                            p.author-role Sinh viên
                        .rating
                            span ⭐⭐⭐⭐⭐
                .testimonial-card(data-animate="fade-up" data-delay="200")
                    .testimonial-content
                        .quote-icon "
                        p.testimonial-text Phương pháp học thông qua trò chơi giúp tôi không bị nhàm chán. Con tôi rất thích học trên Crow và tiến bộ rõ rệt.
                    .testimonial-author
                        .author-avatar
                            img(src="./img/Avata2.png" alt="Thu Hà")
                        .author-info
                            h4.author-name Thu Hà
                            p.author-role Phụ huynh
                        .rating
                            span ⭐⭐⭐⭐⭐

    // CTA Section
    section#cta.cta-section(data-scroll-section)
        .cta-background
            .gradient-orb.orb-4
            .gradient-orb.orb-5
        .container
            .cta-content(data-animate="zoom-in")
                h2.cta-title Sẵn sàng bắt đầu hành trình?
                p.cta-description Tham gia cùng hàng nghìn học viên đã thay đổi cuộc sống với Crow
                .cta-actions
                    a.btn.btn-primary.btn-lg(href="/user/register")
                        span Đăng ký miễn phí
                        i.icon ➜
                    a.btn.btn-outline.btn-lg(href="/course")
                        span Khám phá khóa học

    script(src="./js/home-animations.js")
